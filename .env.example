# Face Detection Service - Environment Variables
# Copy this file to .env and adjust values as needed.

# Directory for log files and SQLite database
LOG_DIR=./logs

# Path to YOLOv8-face model weights (auto-downloaded if not present)
YOLO_MODEL_PATH=yolov8n-face.pt

# Path to MediaPipe BlazeFace model (auto-downloaded if not present)
MEDIAPIPE_MODEL_PATH=blaze_face_short_range.tflite

# Uvicorn settings (for production)
# HOST=0.0.0.0
# PORT=8000
# WORKERS=4
